# ─────────────────────────────────────────────────────────────────────────────
# Release signing configuration — TEMPLATE
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `keystore.properties` (which is git-ignored) and fill in
# the values for your own signing keystore. The real file must NEVER be
# committed — it contains credentials.
#
# Generate a keystore with:
#   keytool -genkeypair -v -keystore keystore/car-crash-detection.keystore \
#           -alias car-crash-detection-key -keyalg RSA -keysize 2048 -validity 10000
#
# If keystore.properties is absent (or the keystore file does not exist),
# the release build falls back to debug signing automatically
# (see app/build.gradle.kts).
# ─────────────────────────────────────────────────────────────────────────────

# Path to the keystore file, relative to the project root.
storeFile=../keystore/car-crash-detection.keystore

# Password for the keystore.
storePassword=CHANGE_ME

# Key alias inside the keystore.
keyAlias=car-crash-detection-key

# Password for the key alias.
keyPassword=CHANGE_ME
